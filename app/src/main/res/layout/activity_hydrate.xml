<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/hydrate_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111113">

    <com.example.lcb.app.ui.hydrate.HydrateHeaderBackgroundView
        android:id="@+id/header_background"
        android:layout_width="match_parent"
        android:layout_height="578dp"
        android:layout_gravity="top" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/hydrate_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_gravity="top"
        android:background="@android:color/transparent"
        android:paddingEnd="6dp"
        app:contentInsetEnd="10dp"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="0dp"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark"
        app:title="" />

    <LinearLayout
        android:id="@+id/header_text_group"
        android:layout_width="220dp"
        android:layout_height="65dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="112dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/amount_text"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:fontFamily="sans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginTop="11dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="#FF999999"
            android:textSize="14sp" />
    </LinearLayout>

    <com.example.lcb.app.ui.hydrate.WaterDropWaveView
        android:id="@+id/water_drop_view"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="236dp" />

    <LinearLayout
        android:id="@+id/drink_button"
        android:layout_width="215dp"
        android:layout_height="48dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="559dp"
        android:background="@drawable/bg_hydrate_drink_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <com.example.lcb.app.ui.hydrate.AddWaterIconView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center_vertical" />

        <TextView
            android:id="@+id/drink_button_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="sans"
            android:includeFontPadding="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/done_button"
        android:layout_width="215dp"
        android:layout_height="48dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="637dp"
        android:background="@drawable/bg_hydrate_done_button"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
</FrameLayout>

