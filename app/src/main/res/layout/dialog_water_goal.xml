<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/water_goal_dialog"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_water_goal_dialog"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="20dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/skip_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:fontFamily="sans"
        android:includeFontPadding="false"
        android:text="@string/hydrate_goal_skip"
        android:textColor="#FF999999"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/hydrate_goal_title"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recommendation_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp"
            android:textColor="#FF999999"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/goal_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/goal_option_1500"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_water_goal_option"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="1,500"
                android:textColor="#FFA1A1A1"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/goal_option_2000"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_water_goal_option_selected"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="2,000"
                android:textColor="#FF2CABFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/goal_option_2500"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_water_goal_option"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="2,500"
                android:textColor="#FFA1A1A1"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/next_button"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_hydrate_drink_button"
            android:fontFamily="sans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/hydrate_goal_next"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
